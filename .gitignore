# Zip umbrella repo — gitignore

# === Common build / runtime ===
.pio/
*.elf
*.bin
*.hex
*.map
*.pyc
*.pyo
__pycache__/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
node_modules/
.pkg-cache/
.next/
out/
*.tsbuildinfo
next-env.d.ts
.env
.env*.local
.vercel/
.idea/
.cursor/
.cursorrules
.DS_Store
*.pem
*.swp
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === ML model weights & TensorRT engines (hardware-built, regenerated on deploy) ===
*.pt
*.onnx
*.engine
*.trt
*.plan

# === Secrets ===
**/secrets.h

# ─── zip-v2 (the robot) ─────────────────────────────────────────────
# Firmware toolchain mirror + build artifacts
/zip-v2/firmware/tools/
/zip-v2/firmware/*/.pio/
/zip-v2/firmware/*/.vscode/
/zip-v2/firmware/archive/*/.pio/
# HUD build artifacts already covered by node_modules/.next at top

# Bridge V1 artifacts
/zip-v2/bridge/*/dist/
/zip-v2/bridge/*/node_modules/
/zip-v2/bridge/*/data/

# ─── jarvis (vision-first AI agent) ─────────────────────────────────
# Vision lab model weights & caches (hardware-specific, large)
/jarvis/depth-lab/models/
/jarvis/perception-lab/models/
/jarvis/perception-lab/trt_cache/
/jarvis/splat-lab/models/
/jarvis/splat-lab/supersplat-viewer/
/jarvis/splat-lab/.venv/

# Vision lab runtime output (regenerated on every scan)
/jarvis/splat-lab/captures/
/jarvis/splat-lab/frames/
/jarvis/splat-lab/output/
/jarvis/splat-lab/scenes/
/jarvis/splat-lab/logs/
/jarvis/depth-lab/run.log
/jarvis/depth-lab/depth_vis.png
/jarvis/depth-lab/test.jpg
/jarvis/perception-lab/run.log
/jarvis/perception-lab/ort_bench.log
/jarvis/perception-lab/bus.jpg

# ─── Misc / runtime ─────────────────────────────────────────────────
/coverage/
/playwright-report/
/test-results/
/artifacts/
/logs/
head.md
TEST_RESULTS.md
